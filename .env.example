# Copy to .env and fill in. The app runs fully WITHOUT the LLM/SMS values
# (it falls back to deterministic mocks) so you can try the MVP immediately.

# --- Database ---
# Dev: SQLite (zero-config). Prod: switch provider to "postgresql" in
# prisma/schema.prisma and use a Postgres + pgvector connection string.
DATABASE_URL="file:./dev.db"

# --- Session signing (REQUIRED in prod) ---
# Generate with: openssl rand -base64 33
SESSION_SECRET="dev-only-insecure-secret-change-me"

# --- LLM domestic gateway (OpenAI-compatible) ---
# Leave blank to use the built-in deterministic fallback (keyword intents,
# extractive FAQ answers). Set these to use a real Persian-capable model.
LLM_BASE_URL=""        # e.g. https://api.<domestic-gateway>.ir/v1
LLM_API_KEY=""
LLM_MODEL="gpt-4o-mini"

# --- SMS / OTP provider (Iranian) ---
# Leave blank to "send" OTP codes to the server console (dev only).
SMS_PROVIDER=""        # e.g. kavenegar | smsir | ghasedak
SMS_API_KEY=""
SMS_SENDER=""
